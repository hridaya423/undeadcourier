* text=auto

# Unity text assets
*.cs text eol=lf diff=csharp
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.overrideController text eol=lf

